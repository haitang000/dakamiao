<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="?attr/colorOnSurface"
            app:title="权限管理" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="24dp">

            <LinearLayout android:id="@+id/rowAccessibility" style="@style/PermRow">

                <LinearLayout style="@style/PermRowText">

                    <TextView style="@style/PermTitle" android:text="无障碍服务" />

                    <TextView style="@style/PermSubtitle" android:text="核心 · 读取钉钉界面并模拟点击" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swAccessibility"
                    style="@style/PermSwitch" />
            </LinearLayout>

            <View style="@style/PermDivider" />

            <LinearLayout android:id="@+id/rowOverlay" style="@style/PermRow">

                <LinearLayout style="@style/PermRowText">

                    <TextView style="@style/PermTitle" android:text="悬浮窗" />

                    <TextView style="@style/PermSubtitle" android:text="停止按钮 · 边框光效 · 确认框" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swOverlay"
                    style="@style/PermSwitch" />
            </LinearLayout>

            <View style="@style/PermDivider" />

            <LinearLayout android:id="@+id/rowNotification" style="@style/PermRow">

                <LinearLayout style="@style/PermRowText">

                    <TextView style="@style/PermTitle" android:text="通知" />

                    <TextView style="@style/PermSubtitle" android:text="打卡进度 · 结果 · 锁屏提醒" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swNotification"
                    style="@style/PermSwitch" />
            </LinearLayout>

            <View style="@style/PermDivider" />

            <LinearLayout android:id="@+id/rowAlarm" style="@style/PermRow">

                <LinearLayout style="@style/PermRowText">

                    <TextView style="@style/PermTitle" android:text="精确闹钟" />

                    <TextView style="@style/PermSubtitle" android:text="定时准点触发，不被系统延迟" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swAlarm"
                    style="@style/PermSwitch" />
            </LinearLayout>

            <View style="@style/PermDivider" />

            <LinearLayout android:id="@+id/rowBattery" style="@style/PermRow">

                <LinearLayout style="@style/PermRowText">

                    <TextView style="@style/PermTitle" android:text="忽略电池优化" />

                    <TextView style="@style/PermSubtitle" android:text="建议 · 防止定时被系统杀后台" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swBattery"
                    style="@style/PermSwitch" />
            </LinearLayout>

            <View style="@style/PermDivider" />

            <LinearLayout android:id="@+id/rowAutostart" style="@style/PermRow">

                <LinearLayout style="@style/PermRowText">

                    <TextView style="@style/PermTitle" android:text="自启动 / 后台运行" />

                    <TextView style="@style/PermSubtitle" android:text="国产 ROM 必开 · 点此前往系统设置" />
                </LinearLayout>

                <TextView style="@style/RowChevron" android:text="›" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="后台保活：开启「定时」后会常驻一条低优先级通知保持后台运行。国产 ROM 请务必开启自启动/后台运行，并把电池设为「无限制」，否则到点可能不触发。"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
