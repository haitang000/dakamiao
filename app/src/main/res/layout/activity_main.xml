<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:a="http://schemas.android.com/apk/res/android"
    a:layout_width="match_parent"
    a:layout_height="match_parent"
    a:fitsSystemWindows="true"
    a:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        a:layout_width="match_parent"
        a:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            a:layout_width="match_parent"
            a:layout_height="?attr/actionBarSize"
            app:menu="@menu/menu_main"
            app:title="打卡喵 🐾" />
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        a:layout_width="match_parent"
        a:layout_height="0dp"
        a:layout_weight="1">

        <!-- ===================== 首页：手动 / 测试 ===================== -->
        <ScrollView
            android:id="@+id/pageHome"
            a:layout_width="match_parent"
            a:layout_height="match_parent"
            a:fillViewport="true">

            <LinearLayout
                a:layout_width="match_parent"
                a:layout_height="wrap_content"
                a:orientation="vertical"
                a:paddingHorizontal="16dp"
                a:paddingBottom="24dp">

                <TextView
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="12dp"
                    a:text="自动打开钉钉并点击打卡。全程可用悬浮按钮 / 通知 / 音量下键随时停止。打卡是否成功请务必自行到钉钉核对。"
                    a:textColor="?attr/colorOnSurfaceVariant"
                    a:textSize="12sp" />

                <TextView
                    style="@style/SectionTitle"
                    a:layout_width="wrap_content"
                    a:layout_height="wrap_content"
                    a:text="手动打卡 / 测试" />

                <Button
                    android:id="@+id/btnTestOn"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="4dp"
                    a:text="立即执行：上班打卡" />

                <Button
                    android:id="@+id/btnTestOff"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="4dp"
                    a:text="立即执行：下班打卡" />

                <Button
                    android:id="@+id/btnStop"
                    style="@style/Widget.Material3.Button"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="12dp"
                    a:text="■ 紧急停止"
                    a:textColor="?attr/colorOnError"
                    app:backgroundTint="?attr/colorError" />

                <Button
                    android:id="@+id/btnDump"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="12dp"
                    a:text="抓取钉钉当前界面（调试，复制发我排查）" />

                <TextView
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="20dp"
                    a:text="提示：\n• 定时打卡触发时手机需处于亮屏/可操作状态（钉钉界面能正常显示才点得到）。\n• 请先在钉钉里走一遍打卡，把每一步按钮上的文字，逐行填到「设置」里对应的步骤。\n• 若打卡需要人脸识别，App 会点到弹脸前一步停下并提醒你本人完成。"
                    a:textColor="?attr/colorOnSurfaceVariant"
                    a:textSize="12sp" />
            </LinearLayout>
        </ScrollView>

        <!-- ===================== 定时 ===================== -->
        <ScrollView
            android:id="@+id/pageSchedule"
            a:layout_width="match_parent"
            a:layout_height="match_parent"
            a:fillViewport="true"
            a:visibility="gone">

            <LinearLayout
                a:layout_width="match_parent"
                a:layout_height="wrap_content"
                a:orientation="vertical"
                a:paddingHorizontal="16dp"
                a:paddingBottom="24dp">

                <TextView
                    style="@style/SectionTitle"
                    a:layout_width="wrap_content"
                    a:layout_height="wrap_content"
                    a:text="定时自动打卡" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swEnabled"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:paddingVertical="8dp"
                    a:text="启用定时自动打卡"
                    a:textSize="16sp" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbWorkday"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:text="仅工作日（周一至周五）" />

                <Button
                    android:id="@+id/btnOnTime"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="8dp"
                    a:text="上班时间：09:00" />

                <Button
                    android:id="@+id/btnOffTime"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="8dp"
                    a:text="下班时间：18:00" />

                <TextView
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="16dp"
                    a:text="到点会先弹 5 秒倒计时确认，无操作自动开始。若锁屏，会点亮屏幕并强提醒你解锁，解锁后自动打卡（安全锁无法自动解锁）。"
                    a:textColor="?attr/colorOnSurfaceVariant"
                    a:textSize="12sp" />
            </LinearLayout>
        </ScrollView>

        <!-- ===================== 设置：步骤 / 关键词 ===================== -->
        <ScrollView
            android:id="@+id/pageSettings"
            a:layout_width="match_parent"
            a:layout_height="match_parent"
            a:fillViewport="true"
            a:visibility="gone">

            <LinearLayout
                a:layout_width="match_parent"
                a:layout_height="wrap_content"
                a:orientation="vertical"
                a:paddingHorizontal="16dp"
                a:paddingBottom="24dp">

                <TextView
                    style="@style/SectionTitle"
                    a:layout_width="wrap_content"
                    a:layout_height="wrap_content"
                    a:text="打卡步骤（一行一个按钮文案，从上到下依次点击）" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="8dp"
                    a:hint="上班步骤（一行一个）">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etOnSteps"
                        a:layout_width="match_parent"
                        a:layout_height="wrap_content"
                        a:gravity="top"
                        a:inputType="textMultiLine"
                        a:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="8dp"
                    a:hint="下班步骤（一行一个）">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etOffSteps"
                        a:layout_width="match_parent"
                        a:layout_height="wrap_content"
                        a:gravity="top"
                        a:inputType="textMultiLine"
                        a:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="8dp"
                    a:hint="判定「打卡成功」的关键词">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSuccess"
                        a:layout_width="match_parent"
                        a:layout_height="wrap_content"
                        a:gravity="top"
                        a:inputType="textMultiLine"
                        a:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="8dp"
                    a:hint="判定「需人脸识别、交还给你」的关键词（拍照通常可选，默认不拦）">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFace"
                        a:layout_width="match_parent"
                        a:layout_height="wrap_content"
                        a:gravity="top"
                        a:inputType="textMultiLine"
                        a:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="8dp"
                    a:hint="需先确认才打卡的关键词（如 外勤、外出）">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etConfirm"
                        a:layout_width="match_parent"
                        a:layout_height="wrap_content"
                        a:gravity="top"
                        a:inputType="textMultiLine"
                        a:minLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbOcr"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="8dp"
                    a:text="启用 OCR 兜底：按钮是图片、读不到文字时，靠截屏文字识别定位（需安卓11+，全程离线不联网）" />

                <Button
                    android:id="@+id/btnResetSteps"
                    style="@style/Widget.Material3.Button.TonalButton"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="8dp"
                    a:text="填入推荐步骤（覆盖上方，再点保存）" />

                <Button
                    android:id="@+id/btnSaveSteps"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:layout_marginTop="4dp"
                    a:text="保存步骤/关键词设置" />
            </LinearLayout>
        </ScrollView>

        <!-- ===================== 权限 ===================== -->
        <ScrollView
            android:id="@+id/pagePermissions"
            a:layout_width="match_parent"
            a:layout_height="match_parent"
            a:fillViewport="true"
            a:visibility="gone">

            <LinearLayout
                a:layout_width="match_parent"
                a:layout_height="wrap_content"
                a:orientation="vertical"
                a:paddingHorizontal="16dp"
                a:paddingBottom="24dp">

                <TextView
                    style="@style/SectionTitle"
                    a:layout_width="wrap_content"
                    a:layout_height="wrap_content"
                    a:text="权限（首次使用请依次开启）" />

                <Button
                    android:id="@+id/btnAccessibility"
                    style="@style/Widget.Material3.Button.TonalButton"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:text="开启无障碍服务（核心）" />

                <TextView
                    android:id="@+id/tvAccessibilityStatus"
                    style="@style/StatusText"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content" />

                <Button
                    android:id="@+id/btnOverlay"
                    style="@style/Widget.Material3.Button.TonalButton"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:text="开启悬浮窗（停止按钮 / 边框 / 确认框）" />

                <TextView
                    android:id="@+id/tvOverlayStatus"
                    style="@style/StatusText"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content" />

                <Button
                    android:id="@+id/btnNotification"
                    style="@style/Widget.Material3.Button.TonalButton"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:text="开启通知权限" />

                <TextView
                    android:id="@+id/tvNotificationStatus"
                    style="@style/StatusText"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content" />

                <Button
                    android:id="@+id/btnExactAlarm"
                    style="@style/Widget.Material3.Button.TonalButton"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:text="允许精确闹钟（定时准点）" />

                <TextView
                    android:id="@+id/tvAlarmStatus"
                    style="@style/StatusText"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content" />

                <Button
                    android:id="@+id/btnBattery"
                    style="@style/Widget.Material3.Button.TonalButton"
                    a:layout_width="match_parent"
                    a:layout_height="wrap_content"
                    a:text="忽略电池优化（建议，防止定时被系统杀）" />
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        a:layout_width="match_parent"
        a:layout_height="wrap_content"
        app:menu="@menu/menu_bottom_nav" />

</LinearLayout>
