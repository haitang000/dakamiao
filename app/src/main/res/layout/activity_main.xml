<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:menu="@menu/menu_main"
            app:title="打卡喵 🐾" />
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ===================== 首页 ===================== -->
        <ScrollView
            android:id="@+id/pageHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="自动打开钉钉并点击打卡。全程可用悬浮按钮 / 通知 / 音量下键随时停止。打卡是否成功请务必自行到钉钉核对。"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />

                <TextView
                    style="@style/SectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="手动打卡 / 测试" />

                <Button
                    android:id="@+id/btnTestOn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="立即执行：上班打卡" />

                <Button
                    android:id="@+id/btnTestOff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="立即执行：下班打卡" />

                <Button
                    android:id="@+id/btnStop"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="■ 紧急停止"
                    android:textColor="?attr/colorOnError"
                    app:backgroundTint="?attr/colorError" />

                <Button
                    android:id="@+id/btnDump"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="抓取钉钉当前界面（调试，复制发我排查）" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="提示：\n• 定时打卡触发时手机需处于亮屏/可操作状态。\n• 请先在钉钉里走一遍打卡，把每步按钮文字填到「设置 → 打卡步骤」里。\n• 若打卡需要人脸识别，App 会点到弹脸前一步停下并提醒你本人完成。"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>
        </ScrollView>

        <!-- ===================== 定时 ===================== -->
        <ScrollView
            android:id="@+id/pageSchedule"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="24dp">

                <TextView
                    style="@style/SectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="定时自动打卡" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/swEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="8dp"
                    android:text="启用定时自动打卡"
                    android:textSize="16sp" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/cbWorkday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="仅工作日（周一至周五）" />

                <Button
                    android:id="@+id/btnOnTime"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="上班时间：09:00" />

                <Button
                    android:id="@+id/btnOffTime"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="下班时间：18:00" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="到点会先弹 5 秒倒计时确认，无操作自动开始。若锁屏，会点亮屏幕并强提醒你解锁，解锁后自动打卡（安全锁无法自动解锁）。"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>
        </ScrollView>

        <!-- ===================== 设置（多级菜单） ===================== -->
        <ScrollView
            android:id="@+id/pageSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:id="@+id/rowPermissions"
                    style="@style/PermRow">

                    <LinearLayout style="@style/PermRowText">

                        <TextView style="@style/PermTitle" android:text="权限管理" />

                        <TextView style="@style/PermSubtitle" android:text="无障碍 · 悬浮窗 · 通知 · 闹钟 · 后台" />
                    </LinearLayout>

                    <TextView style="@style/RowChevron" android:text="›" />
                </LinearLayout>

                <View style="@style/PermDivider" />

                <LinearLayout
                    android:id="@+id/rowSteps"
                    style="@style/PermRow">

                    <LinearLayout style="@style/PermRowText">

                        <TextView style="@style/PermTitle" android:text="打卡步骤与设置" />

                        <TextView style="@style/PermSubtitle" android:text="导航步骤 · 关键词 · OCR · 退出后台" />
                    </LinearLayout>

                    <TextView style="@style/RowChevron" android:text="›" />
                </LinearLayout>

                <View style="@style/PermDivider" />

                <LinearLayout
                    android:id="@+id/rowAbout"
                    style="@style/PermRow">

                    <LinearLayout style="@style/PermRowText">

                        <TextView style="@style/PermTitle" android:text="关于打卡喵" />

                        <TextView style="@style/PermSubtitle" android:text="版本信息 · 检查更新 · 开源地址" />
                    </LinearLayout>

                    <TextView style="@style/RowChevron" android:text="›" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/menu_bottom_nav" />

</LinearLayout>
