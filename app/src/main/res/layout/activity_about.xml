<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="?attr/colorOnSurface"
            app:title="关于" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginTop="28dp"
                android:contentDescription="打卡喵"
                android:src="@mipmap/ic_launcher" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="打卡喵"
                android:textColor="?attr/colorOnSurface"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="版本 —"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnCheckUpdate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:minWidth="180dp"
                android:text="检查更新" />

            <TextView
                android:id="@+id/tvUpdateStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnDownload"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minWidth="180dp"
                android:text="下载更新"
                android:visibility="gone" />

            <View
                style="@style/PermDivider"
                android:layout_marginTop="24dp" />

            <LinearLayout
                android:id="@+id/rowGithub"
                style="@style/PermRow">

                <LinearLayout style="@style/PermRowText">

                    <TextView style="@style/PermTitle" android:text="GitHub 项目主页" />

                    <TextView style="@style/PermSubtitle" android:text="查看源码 · 手动下载 Release" />
                </LinearLayout>

                <TextView style="@style/RowChevron" android:text="›" />
            </LinearLayout>

            <View style="@style/PermDivider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:lineSpacingMultiplier="1.3"
                android:text="打卡喵是开源的自动化辅助工具，随时可能失效，打卡是否成功请务必自行到钉钉核对，一切后果自负。请只从官方 GitHub 仓库下载，第三方渠道可能植入恶意代码。"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
